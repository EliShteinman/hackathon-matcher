# Application
APP_NAME="Hackathon Matcher"
BASE_URL="http://localhost:8000"
SESSION_SECRET_KEY="change-me-to-a-random-secret-key"
TOKEN_EXPIRY_HOURS=72

# Admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-to-a-strong-password"

# Database
DATABASE__PATH="hackathon_matcher.db"

# Email (SMTP)
EMAIL__SMTP_HOST="smtp.gmail.com"
EMAIL__SMTP_PORT=587
EMAIL__SMTP_USERNAME=""
EMAIL__SMTP_PASSWORD=""
EMAIL__FROM_ADDRESS="hackathon@example.com"
EMAIL__FROM_NAME="Hackathon Matcher"
EMAIL__USE_TLS=true
EMAIL__ENABLED=false

# Excel Column Mapping (Hebrew defaults match standard template)
# EXCEL__SHEET_NAME=
EXCEL__COLUMN_ID_NUMBER="מספר זהות"
EXCEL__COLUMN_EMAIL="email"
EXCEL__COLUMN_FULL_NAME="שם מלא"
EXCEL__COLUMN_BRANCH="סניף מכינה"
EXCEL__COLUMN_CLASS_NAME="כיתה"
EXCEL__COLUMN_MATCH_STATUS="סטטוס שידוך"
EXCEL__HEADER_ROW=1

# Logging
LOGGING__LEVEL="INFO"
LOGGING__FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOGGING__FILE_PATH="hackathon_matcher.log"
